# LLM 提供商配置
# 可选值: ollama (默认) | minimax | openai
LLM_PROVIDER=ollama

# 检索引擎: vector (默认, 向量检索) | pageindex (推理式) | keyword (关键词匹配)
SEARCH_ENGINE=vector

# --- Ollama (本地) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:0.8b

# --- MiniMax CN (国内云 API) ---
# MINIMAX_CN_API_KEY=sk-...
# MINIMAX_CN_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_CN_MODEL=MiniMax-M2.7

# --- OpenAI 兼容 API ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.xxx.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Ollama OpenAI 兼容端点（向量检索 / PageIndex 使用）
OPENAI_API_KEY=sk-dummy
OPENAI_API_BASE=http://localhost:11434/v1

# --- 模型下载（仅首次需要，下载后删掉即可）---
# settings.py 默认 HF_HUB_OFFLINE=1 禁用网络，防止断网时 huggingface 重试挂死。
# 首次部署需临时打开并配国内镜像来下载 bge-m3 / bge-reranker 等模型：
# HF_HUB_OFFLINE=0
# HF_ENDPOINT=https://hf-mirror.com

# 模型也可通过 ModelScope 预下载到本地（完全离线部署推荐）：
# modelscope download BAAI/bge-m3 --local_dir ~/.cache/modelscope/hub/BAAI/bge-m3
# modelscope download BAAI/bge-reranker-v2-m3 --local_dir ~/.cache/modelscope/hub/BAAI/bge-reranker-v2-m3